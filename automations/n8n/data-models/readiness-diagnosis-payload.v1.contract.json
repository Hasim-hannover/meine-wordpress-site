{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hasimuener.de/contracts/readiness-diagnosis-payload.v1.contract.json",
  "title": "Readiness Diagnosis Payload v1",
  "description": "Privacy-first submit payload for the paid Readiness-Diagnose. The default path contains no clear name, no email address, no phone number, and no personal end-customer data.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "client",
    "inputs",
    "attribution",
    "consent",
    "routing"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "submitted_at",
        "source_url",
        "intake_variant",
        "consent_version"
      ],
      "properties": {
        "schema_version": {
          "const": "readiness-diagnosis-payload.v1"
        },
        "submitted_at": {
          "type": "string",
          "format": "date-time"
        },
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "intake_variant": {
          "const": "readiness_diagnosis"
        },
        "consent_version": {
          "const": "readiness-diagnosis-consent.v1"
        }
      }
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "industry",
        "employee_range",
        "country",
        "plz_region"
      ],
      "properties": {
        "industry": {
          "type": "string",
          "enum": [
            "solar",
            "heat_pump",
            "solar_heat_pump_storage",
            "shk",
            "other"
          ]
        },
        "employee_range": {
          "type": "string",
          "enum": [
            "1_4",
            "5_9",
            "10_25",
            "26_50",
            "50_plus",
            "unknown"
          ]
        },
        "country": {
          "type": "string",
          "enum": [
            "DE",
            "AT",
            "CH"
          ]
        },
        "plz_region": {
          "type": "string",
          "description": "Coarse postal region only. For Germany use the first two digits, not a full postal code.",
          "minLength": 2,
          "maxLength": 12,
          "pattern": "^[A-Z0-9_-]{2,12}$"
        }
      }
    },
    "inputs": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "website_url",
        "offer_focus",
        "ad_budget_range",
        "tracking",
        "crm",
        "lead_process"
      ],
      "properties": {
        "website_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "offer_focus": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "pv",
              "storage",
              "heat_pump",
              "wallbox",
              "maintenance",
              "other"
            ]
          }
        },
        "ad_budget_range": {
          "type": "string",
          "enum": [
            "under_5000",
            "5000_10000",
            "10000_25000",
            "25000_plus",
            "unknown"
          ]
        },
        "tracking": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "pixel_present_self_reported",
            "gtm_present_self_reported",
            "consent_mode_self_reported",
            "server_side_tracking_self_reported",
            "meta_capi_self_reported"
          ],
          "properties": {
            "pixel_present_self_reported": {
              "$ref": "#/$defs/self_report"
            },
            "gtm_present_self_reported": {
              "$ref": "#/$defs/self_report"
            },
            "consent_mode_self_reported": {
              "$ref": "#/$defs/self_report"
            },
            "server_side_tracking_self_reported": {
              "$ref": "#/$defs/self_report"
            },
            "meta_capi_self_reported": {
              "$ref": "#/$defs/self_report"
            }
          }
        },
        "crm": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "crm_present_self_reported",
            "lead_status_tracking_self_reported",
            "response_time_self_reported"
          ],
          "properties": {
            "crm_present_self_reported": {
              "$ref": "#/$defs/self_report"
            },
            "lead_status_tracking_self_reported": {
              "$ref": "#/$defs/self_report"
            },
            "response_time_self_reported": {
              "type": "string",
              "enum": [
                "under_1h",
                "1_4h",
                "same_day",
                "next_day_or_later",
                "unknown"
              ]
            }
          }
        },
        "lead_process": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "monthly_lead_volume_range",
            "lead_quality_self_reported",
            "biggest_bottleneck"
          ],
          "properties": {
            "monthly_lead_volume_range": {
              "type": "string",
              "enum": [
                "0_10",
                "11_30",
                "31_75",
                "76_plus",
                "unknown"
              ]
            },
            "lead_quality_self_reported": {
              "type": "string",
              "enum": [
                "good",
                "mixed",
                "poor",
                "unknown"
              ]
            },
            "biggest_bottleneck": {
              "type": "string",
              "enum": [
                "too_few_requests",
                "wrong_requests",
                "tracking_unclear",
                "crm_unclear",
                "response_speed",
                "unknown"
              ]
            }
          }
        }
      }
    },
    "attribution": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "landing_page_url",
        "entry_page_url",
        "previous_internal_url",
        "referrer",
        "utm",
        "click_ids"
      ],
      "properties": {
        "landing_page_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "entry_page_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "previous_internal_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        },
        "referrer": {
          "type": [
            "string",
            "null"
          ],
          "maxLength": 2048
        },
        "utm": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source",
            "medium",
            "campaign",
            "content",
            "term"
          ],
          "properties": {
            "source": {
              "type": [
                "string",
                "null"
              ],
              "maxLength": 128
            },
            "medium": {
              "type": [
                "string",
                "null"
              ],
              "maxLength": 128
            },
            "campaign": {
              "type": [
                "string",
                "null"
              ],
              "maxLength": 256
            },
            "content": {
              "type": [
                "string",
                "null"
              ],
              "maxLength": 256
            },
            "term": {
              "type": [
                "string",
                "null"
              ],
              "maxLength": 256
            }
          }
        },
        "click_ids": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "gclid",
            "fbclid",
            "msclkid"
          ],
          "properties": {
            "gclid": {
              "type": [
                "string",
                "null"
              ],
              "maxLength": 256
            },
            "fbclid": {
              "type": [
                "string",
                "null"
              ],
              "maxLength": 512
            },
            "msclkid": {
              "type": [
                "string",
                "null"
              ],
              "maxLength": 256
            }
          }
        }
      }
    },
    "consent": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "privacy_processing_accepted",
        "marketing",
        "analytics",
        "timestamp",
        "text_version",
        "text_hash"
      ],
      "properties": {
        "privacy_processing_accepted": {
          "const": true
        },
        "marketing": {
          "type": "boolean"
        },
        "analytics": {
          "type": "boolean"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "text_version": {
          "const": "readiness-diagnosis-consent.v1"
        },
        "text_hash": {
          "$ref": "#/$defs/sha256"
        }
      }
    },
    "delivery": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "requested",
        "email",
        "consent"
      ],
      "properties": {
        "requested": {
          "const": true
        },
        "email": {
          "type": "string",
          "format": "email",
          "maxLength": 254
        },
        "consent": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "email_delivery_accepted",
            "timestamp",
            "text_version",
            "text_hash"
          ],
          "properties": {
            "email_delivery_accepted": {
              "const": true
            },
            "timestamp": {
              "type": "string",
              "format": "date-time"
            },
            "text_version": {
              "const": "readiness-diagnosis-email-delivery-consent.v1"
            },
            "text_hash": {
              "$ref": "#/$defs/sha256"
            }
          }
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_workflow",
        "target_webhook_path",
        "route_key",
        "branch_status"
      ],
      "properties": {
        "target_workflow": {
          "type": "string",
          "enum": [
            "audit-funnel__instant-results__live-import",
            "audit-funnel__customer-journey-audit__refactor"
          ]
        },
        "target_webhook_path": {
          "const": "audit-consultation"
        },
        "route_key": {
          "const": "readiness_diagnosis"
        },
        "branch_status": {
          "const": "mvp"
        }
      }
    }
  },
  "$defs": {
    "self_report": {
      "type": "string",
      "enum": [
        "yes",
        "no",
        "unknown"
      ]
    },
    "sha256": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    }
  },
  "examples": [
    {
      "meta": {
        "schema_version": "readiness-diagnosis-payload.v1",
        "submitted_at": "2026-05-02T20:30:00.000Z",
        "source_url": "https://hasimuener.de/readiness-diagnose/",
        "intake_variant": "readiness_diagnosis",
        "consent_version": "readiness-diagnosis-consent.v1"
      },
      "client": {
        "industry": "solar_heat_pump_storage",
        "employee_range": "10_25",
        "country": "DE",
        "plz_region": "30"
      },
      "inputs": {
        "website_url": "https://example.de",
        "offer_focus": [
          "pv",
          "storage",
          "heat_pump"
        ],
        "ad_budget_range": "5000_10000",
        "tracking": {
          "pixel_present_self_reported": "unknown",
          "gtm_present_self_reported": "yes",
          "consent_mode_self_reported": "unknown",
          "server_side_tracking_self_reported": "no",
          "meta_capi_self_reported": "unknown"
        },
        "crm": {
          "crm_present_self_reported": "yes",
          "lead_status_tracking_self_reported": "no",
          "response_time_self_reported": "same_day"
        },
        "lead_process": {
          "monthly_lead_volume_range": "11_30",
          "lead_quality_self_reported": "mixed",
          "biggest_bottleneck": "tracking_unclear"
        }
      },
      "attribution": {
        "landing_page_url": "https://hasimuener.de/readiness-diagnose/",
        "entry_page_url": "https://hasimuener.de/energie-fahrplan-demo/",
        "previous_internal_url": "https://hasimuener.de/e3-new-energy/",
        "referrer": null,
        "utm": {
          "source": null,
          "medium": null,
          "campaign": null,
          "content": null,
          "term": null
        },
        "click_ids": {
          "gclid": null,
          "fbclid": null,
          "msclkid": null
        }
      },
      "consent": {
        "privacy_processing_accepted": true,
        "marketing": false,
        "analytics": false,
        "timestamp": "2026-05-02T20:30:00.000Z",
        "text_version": "readiness-diagnosis-consent.v1",
        "text_hash": "sha256:aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
      },
      "routing": {
        "target_workflow": "audit-funnel__instant-results__live-import",
        "target_webhook_path": "audit-consultation",
        "route_key": "readiness_diagnosis",
        "branch_status": "mvp"
      }
    }
  ]
}
