{
  "name": "Audit Funnel - Instant Results V3",
  "kind": "target-spec",
  "version": "v3-target",
  "status": "target",
  "note": "Architecture spec for the refactor. This file documents the desired n8n structure and payload contract, but is not a drop-in live import.",
  "endpoints": [
    {
      "method": "POST",
      "path": "/webhook/audit",
      "purpose": "Start a URL-only audit run and return jobId + processing state immediately."
    },
    {
      "method": "GET",
      "path": "/webhook/audit-status?jobId=...",
      "purpose": "Return processing, done, expired or error for the current job."
    },
    {
      "method": "POST",
      "path": "/webhook/audit-consultation",
      "purpose": "Accept a native consultation request after the on-page result and route it via Brevo SMTP or CRM."
    }
  ],
  "remove_nodes_from_v2": [
    "IF Email Capture?",
    "Load Stored Audit For Email",
    "IF Stored Audit Ready?",
    "Respond Email Capture State",
    "IF Auto Email Requested",
    "Prepare Auto Email Request",
    "Build Email HTML",
    "Send email",
    "IF Email Response Needed?",
    "Respond Email Capture OK"
  ],
  "phases": [
    {
      "name": "start",
      "goal": "Minimal friction and immediate acknowledgement.",
      "nodes": [
        {
          "name": "Webhook Start",
          "type": "webhook",
          "input": {
            "url": "required"
          },
          "output": {
            "jobId": "generated",
            "status": "processing"
          }
        },
        {
          "name": "URL Validator",
          "type": "code",
          "responsibility": [
            "normalize URL",
            "block private / internal hosts",
            "rate limit by IP",
            "create jobId"
          ]
        },
        {
          "name": "Respond Accepted",
          "type": "respondToWebhook",
          "response": {
            "ok": true,
            "status": "processing",
            "message": "Audit gestartet. Ergebnisse werden auf der Seite angezeigt."
          }
        },
        {
          "name": "Store Processing",
          "type": "code",
          "storage": "workflow static data or external store",
          "fields": [
            "status",
            "request.url",
            "request.domain",
            "storedAt",
            "updatedAt",
            "expiresAt"
          ]
        }
      ]
    },
    {
      "name": "analysis",
      "goal": "Generate a fast, high-signal diagnosis without email or PDF delivery logic.",
      "nodes": [
        {
          "name": "Raw HTML Fetch",
          "type": "httpRequest",
          "purpose": "Read live HTML and head tags."
        },
        {
          "name": "Readable Snapshot",
          "type": "httpRequest",
          "purpose": "Fetch readable page text via Jina or equivalent reader."
        },
        {
          "name": "PageSpeed Mobile",
          "type": "httpRequest",
          "purpose": "Read mobile Lighthouse data."
        },
        {
          "name": "PageSpeed Retry",
          "type": "httpRequest",
          "optional": true,
          "purpose": "Retry PageSpeed once if Google responds empty or unstable."
        },
        {
          "name": "Sitemap Fetch",
          "type": "httpRequest",
          "purpose": "Read sitemap_index.xml or sitemap.xml."
        },
        {
          "name": "Analyze Signals",
          "type": "code",
          "responsibility": [
            "extract SEO, tracking, trust and conversion signals",
            "normalize performance metrics",
            "classify WordPress, sitemap and legal basics"
          ]
        },
        {
          "name": "Keyword Intent Builder",
          "type": "openai",
          "purpose": "Generate six commercial keywords, branch, location and avg order value."
        },
        {
          "name": "SERP Check",
          "type": "httpRequest",
          "purpose": "Check Google Custom Search results for the commercial keyword set."
        },
        {
          "name": "Build Diagnosis V3",
          "type": "code",
          "responsibility": [
            "prioritize top 3 findings",
            "build opportunity range instead of fake single-value precision",
            "prepare detail sections for frontend"
          ]
        },
        {
          "name": "Write Strategic Summary",
          "type": "openai",
          "purpose": "Compress the diagnosis into short, high-pressure advisory copy."
        },
        {
          "name": "Build Frontend Payload V3",
          "type": "code",
          "contract": "automations/n8n/data-models/audit-frontend-payload.v3.contract.json",
          "output": [
            "meta",
            "verdict",
            "highlights",
            "findings",
            "opportunity",
            "details.sections",
            "story",
            "cta"
          ]
        },
        {
          "name": "Store Results",
          "type": "code",
          "responsibility": [
            "save status done",
            "save payload under jobId",
            "cleanup expired jobs"
          ]
        }
      ]
    },
    {
      "name": "status",
      "goal": "Return compact polling responses for the frontend.",
      "nodes": [
        {
          "name": "Webhook Status",
          "type": "webhook"
        },
        {
          "name": "Lookup Result",
          "type": "code",
          "response_states": [
            "processing",
            "done",
            "expired",
            "error"
          ]
        },
        {
          "name": "Respond Status",
          "type": "respondToWebhook"
        }
      ]
    },
    {
      "name": "consultation",
      "goal": "Handle the post-result consultation request without plugin dependency.",
      "nodes": [
        {
          "name": "Webhook Consultation",
          "type": "webhook",
          "input": {
            "name": "required",
            "email": "required",
            "company": "optional",
            "message": "optional",
            "jobId": "optional",
            "url": "optional",
            "domain": "optional",
            "primaryFinding": "optional"
          }
        },
        {
          "name": "Consultation Validator",
          "type": "code",
          "responsibility": [
            "validate required fields",
            "normalize email",
            "add source metadata"
          ]
        },
        {
          "name": "Send Consultation Notification",
          "type": "emailSend",
          "provider": "Brevo SMTP",
          "purpose": "Send the consultation request to the sales / inbox target."
        },
        {
          "name": "Respond Consultation",
          "type": "respondToWebhook",
          "response": {
            "ok": true,
            "status": "accepted",
            "message": "Beratung angefragt."
          }
        }
      ]
    }
  ],
  "frontend_touchpoints": [
    "blocksy-child/assets/js/audit-live.js",
    "blocksy-child/assets/css/audit-results.css",
    "docs/references/audit-page-editor-snippet-v3.html"
  ],
  "contracts": [
    "automations/n8n/data-models/audit-frontend-payload.v3.contract.json"
  ],
  "success_criteria": [
    "Audit start requires only a URL.",
    "No email or report-delivery branch exists in the audit runner.",
    "Results appear directly on the page and prioritize top 3 findings.",
    "Primary CTA after the result is consultation, not email capture or PDF report.",
    "Consultation submit works without Fluent Forms."
  ]
}
